{
    "description": "SolarWinds Observability logging driver",
    "documentation": "https://github.com/omnimodular/docker-plugin-swo",
    "entrypoint": ["/usr/bin/docker-swo-log-driver"],
    "interface": {
        "types": ["docker.logdriver/1.0"],
        "socket": "swo.sock"
    },
    "network": {
        "type": "host"
    },
    "env": [
        {
            "name": "LOG_LEVEL",
            "description": "Plugin log level (debug, info, warn, error)",
            "value": "info",
            "settable": ["value"]
        }
    ]
}
